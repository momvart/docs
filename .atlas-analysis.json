{
  "projectType": "cli-tool",
  "projectName": "Leaf",
  "projectDescription": "Leaf is a concolic execution framework for Rust that instruments programs at the MIR level via a custom compiler wrapper (`leafc`) and pluggable runtime backends to enable dynamic symbolic analysis, diverging input generation, and hybrid fuzzing.",
  "theme": "aspen",
  "primaryColor": "#3B6E3C",
  "lightColor": "#5AA65C",
